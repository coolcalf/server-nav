# 管理员账号（首次启动时若数据库无用户则据此创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# JWT 签名密钥，生产请使用强随机串：openssl rand -base64 48
AUTH_SECRET=replace-with-a-long-random-string

# SQLite 数据文件路径（相对项目根目录或绝对路径）
DB_PATH=./data/app.db

# ─── 服务健康检查 ───────────────────────────────────────
# 单次 HTTP/TCP 探测超时（毫秒）
HEALTH_TIMEOUT_MS=5000
# 服务巡检周期（毫秒）
HEALTH_INTERVAL_MS=30000

# ─── 主机监控（Prometheus exporter） ──────────────────────
# 单次 /metrics 抓取超时
HOST_TIMEOUT_MS=5000
# 主机巡检周期
HOST_INTERVAL_MS=30000
# 主机历史采样保留天数（超过则自动清理）
HOST_RETENTION_DAYS=7
