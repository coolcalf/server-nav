# 宿主机暴露端口（容器内固定监听 3000）
HOST_PORT=3000

# Docker 构建时是否安装编译链。
# better-sqlite3 预编译包不可用时改成 true。
INSTALL_BUILD_DEPS=false

# 登录 cookie 是否强制带 Secure。
# 直接用 http://IP:端口 访问时保持 false；放到 HTTPS 反代后改成 true。
COOKIE_SECURE=false

# 管理员账号（首次启动时若数据库无用户则据此创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# JWT 签名密钥，生产请使用强随机串：openssl rand -base64 48
AUTH_SECRET=replace-with-a-long-random-string

# SQLite 数据文件路径（Docker 中建议保持 /data/app.db）
DB_PATH=/data/app.db

# ─── 服务健康检查 ───────────────────────────────────────
# 单次 HTTP/TCP 探测超时（毫秒）
HEALTH_TIMEOUT_MS=5000
# 服务巡检周期（毫秒）
HEALTH_INTERVAL_MS=30000

# ─── 主机监控（Prometheus exporter） ──────────────────────
# 单次 /metrics 抓取超时
HOST_TIMEOUT_MS=5000
# 主机巡检周期
HOST_INTERVAL_MS=30000
# 主机历史采样保留天数（超过则自动清理）
HOST_RETENTION_DAYS=7
